<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_bg"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👋 Welcome!"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's set up your account in 30 seconds."
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"/>

        <!-- Step indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="32dp">
            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/accent_green"
                android:layout_marginEnd="4dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/accent_green"
                android:layout_marginEnd="4dp"/>
            <View
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:background="@color/accent_green"/>
        </LinearLayout>

        <!-- Name field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Name"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.05"/>

        <EditText
            android:id="@+id/etOnboardName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edittext"
            android:hint="e.g. Rahul Sharma"
            android:textColorHint="@color/text_light"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName"
            android:singleLine="true"/>

        <!-- Monthly Budget field -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Budget"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.05"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etOnboardBudget"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_edittext"
            android:hint="e.g. 15000"
            android:textColorHint="@color/text_light"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="numberDecimal"
            android:singleLine="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a monthly spending limit to track your budget."
            android:textSize="12sp"
            android:textColor="@color/text_light"
            android:layout_marginTop="4dp"/>

        <!-- Currency picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferred Currency"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.05"
            android:layout_marginTop="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCurrencyINR"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="₹  INR"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/accent_green"
                android:textColor="@color/accent_green"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCurrencyUSD"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="$  USD"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/divider"
                android:textColor="@color/text_secondary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCurrencyEUR"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="€  EUR"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/divider"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- Continue button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOnboardContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:text="Continue to Dashboard →"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="16dp"/>

        <!-- Skip link -->
        <TextView
            android:id="@+id/tvOnboardSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Skip for now"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

    </LinearLayout>
</ScrollView>
