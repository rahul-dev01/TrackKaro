<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.TrackKaro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorSecondaryContainer">#00000000</item>
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:statusBarColor">?android:attr/colorBackground</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Theme.TrackKaro" parent="Base.Theme.TrackKaro"/>

    <style name="Theme.TrackKaro.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/accent_green_mid</item>
        <item name="android:statusBarColor">@color/accent_green_mid</item>
    </style>

    <style name="TrackKaroButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/accent_green</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <style name="TrackKaroButtonOutline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/accent_green</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

</resources>
